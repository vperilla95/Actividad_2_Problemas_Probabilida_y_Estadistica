#interpretación del tamaño del efecto en unidades de presión arterial
mu0 <- 120
sigma <- 15
tabla_efecto_mmHg <- data.frame(
`Tamaño del efecto (d)` = c(0.2, 0.5, 0.8),
Clasificación = c("Pequeño", "Mediano", "Grande"),
`Diferencia esperada (mmHg)` = c(0.2 * sigma, 0.5 * sigma, 0.8 * sigma),
`Media esperada si aumenta (mmHg)` = c(mu0 + 0.2 * sigma,
mu0 + 0.5 * sigma,
mu0 + 0.8 * sigma),
`Media esperada si disminuye (mmHg)` = c(mu0 - 0.2 * sigma,
mu0 - 0.5 * sigma,
mu0 - 0.8 * sigma)
)
tabla_efecto_mmHg[, -2] <- lapply(tabla_efecto_mmHg[, -2], round, 2)
knitr::kable(
tabla_efecto_mmHg,
caption = "Interpretación del tamaño del efecto en unidades de presión arterial",
align = c("c", "c", "c", "c", "c"),
booktabs = TRUE
) %>%
kableExtra::kable_styling(
full_width = FALSE,
position = "center"
)
ggplot(all_results, aes(x = n, y = power, color = d)) +
geom_line(linewidth = 1.2) +
geom_hline(yintercept = 0.8,
linetype = "dashed",
color = "gray40") +
facet_wrap(~alpha, ncol = 1) +
scale_color_manual(
values = c("#1b9e77", "#d95f02", "#7570b3"),
name = "Tamaño del efecto"
) +
scale_x_continuous(
breaks = seq(0, 1000, by = 50)
) +
scale_y_continuous(
breaks = seq(0, 1, 0.1)
) +
labs(
title = "Potencia estadística según tamaño muestral",
subtitle = "Comparación por tamaño del efecto y nivel de significancia",
x = "Tamaño de muestra (n)",
y = "Potencia estadística"
) +
theme_minimal(base_size = 13) +
theme(
plot.title = element_text(face = "bold", size = 16),
legend.position = "bottom",
strip.text = element_text(face = "bold"),
panel.grid.major = element_line(color = "gray80"),
panel.grid.minor = element_line(color = "gray90")
)
