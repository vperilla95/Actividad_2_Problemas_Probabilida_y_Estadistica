) +
theme_minimal() +
theme(legend.position = "none")
paquetes <- c("ggplot2", "dplyr","tidyr", "tibble","purrr", "knitr", "kableExtra","bookdown")
for (p in paquetes) {
if (!require(p, character.only = TRUE)) {
install.packages(p, repos = "https://cloud.r-project.org")
library(p, character.only = TRUE)
} else {
library(p, character.only = TRUE)
}
}
alpha <-3
sigma <- 2
mu_verdadera <- alpha *sigma
var_poblacional <- alpha * sigma^2
seed <- 456
n_base <- 10
B_graficos <- 100
B_sim <- 10000
estimador1 <- function(x) mean(x)
estimador2 <- function(x) (min(x)+max(x)) / 2
estimador3 <- function(x) min(x)
estimador4 <- function(x) sum(x) / (length(x) + 1)
#estimadores <- list(
#  "Estimador 1" = estimador1,
#  "Estimador 2" = estimador2,
#  "Estimador 3" = estimador3,
#  "Estimador 4" = estimador4
#)
tabla_parametros <- tibble(
Parámetro = c("Forma alpha","Escala sigma", "Media verdadera mu", "Varianza poblacional","Semilla", "n base","Simulaciones para gráficas", "Simulaciones para análisis"),
Valor = c(alpha, sigma, mu_verdadera, var_poblacional, seed, n_base, B_graficos, B_sim)
)
knitr::kable(
tabla_parametros,
caption = "Constantes utilizadas en el desarrollo del problema.",
digits = 4,
format = "html"
) |>
kableExtra::kable_styling(
bootstrap_options = c("striped", "hover", "bordered"),
full_width = FALSE,
font_size = 12
)
calcular_estimadores <- function(n, alpha = 3, sigma = 2) {
x <- rgamma(n, shape = alpha, scale = sigma)
tibble(
`Estimador 1` = estimador1(x),
`Estimador 2` = estimador2(x),
`Estimador 3` = estimador3(x),
`Estimador 4` = estimador4(x)
)
}
set.seed(seed)
res_100 <- map_dfr(1:B_graficos, ~ calcular_estimadores(n = n_base, alpha = alpha, sigma = sigma), .id = "Muestra") |>
mutate(Muestra = as.integer(Muestra))
res_100_largo <- res_100 |>
pivot_longer(cols = starts_with("Estimador"), names_to = "Estimador", values_to = "Valor")
resumen_100 <- res_100_largo |>
group_by(Estimador) |>
summarise(
Media = mean(Valor),
DesvEst = sd(Valor),
Min = min(Valor),
Max = max(Valor),
.groups = "drop"
)
knitr::kable(
resumen_100,
caption = "Resumen descriptivo de los estimadores con 100 muestras de tamaño 10.",
digits = 4,
format = "html"
) |>
kableExtra::kable_styling(
bootstrap_options = c("striped", "hover", "bordered"),
full_width = FALSE,
font_size = 12
)
ggplot(res_100_largo, aes(x = Valor, fill = Estimador, color = Estimador)) +
geom_histogram(aes(y = after_stat(density)), bins = 15, alpha = 0.25, position = "identity") +
geom_density(linewidth = 1, alpha = 0.4) +
# media verdadera
geom_vline(xintercept = mu_verdadera, linetype = "dashed", linewidth = 1) +
# media del estimador
geom_vline(data = resumen_100,
aes(xintercept = Media),
color = "orange",
linewidth = 1) +
facet_wrap(~ Estimador, scales = "free", ncol = 2) +
labs(
title = "Simulación de estimadores con 100 muestras",
subtitle = paste0("Línea punteada: media verdadera = ", mu_verdadera,
" | Línea naranja: media del estimador"),
x = "Valor del estimador",
y = "Densidad"
) +
theme_minimal() +
theme(legend.position = "none")
set.seed(seed)
res_ins <- map_dfr(1:B_sim, ~ calcular_estimadores(n = n_base, alpha = alpha, sigma = sigma)) |>
pivot_longer(cols = everything(), names_to = "Estimador", values_to = "Valor")
tabla_insesgadez <- res_ins |>
group_by(Estimador) |>
summarise(
Media_Estimada = mean(Valor),
Sesgo = mean(Valor) - mu_verdadera,
Sesgo_Absoluto = abs(Sesgo),
Varianza = var(Valor),
.groups = "drop"
) |>
arrange(Sesgo_Absoluto)
knitr::kable(
tabla_insesgadez,
caption = "Evaluación de insesgadez por simulación con 10.000 repeticiones y n = 10.",
digits = 5,
format = "html"
) |>
kableExtra::kable_styling(
bootstrap_options = c("striped", "hover", "bordered"),
full_width = FALSE,
font_size = 12
)
ggplot(tabla_insesgadez, aes(x = reorder(Estimador, Media_Estimada), y = Media_Estimada, fill = Estimador)) +
geom_col(alpha = 0.8) +
geom_hline(yintercept = mu_verdadera, linetype = "dashed", linewidth = 1) +
coord_flip() +
labs(
title = "Comparación de medias empíricas",
subtitle = paste0("Línea punteada: mu verdadera = ", mu_verdadera),
x = "Estimador",
y = "Media empírica"
) +
theme_minimal() +
theme(legend.position = "none")
n_values <- c(5, 10, 20, 30, 50, 60, 70, 80, 90, 100, 200, 300, 400, 500, 600, 800, 1000)
simular_por_n <- function(n, B = 5000, alpha = 3, sigma = 2) {
reps <- map_dfr(1:B, ~ calcular_estimadores(n = n, alpha = alpha, sigma = sigma)) |>
pivot_longer(cols = everything(), names_to = "Estimador", values_to = "Valor")
reps |>
group_by(Estimador) |>
summarise(
n = n,
Media = mean(Valor),
Varianza = var(Valor),
DesvEst = sd(Valor),
CV = sd(Valor) / abs(mean(Valor)),
MSE = mean((Valor - mu_verdadera)^2),
.groups = "drop"
)
}
set.seed(seed)
res_consistencia <- map_dfr(n_values, simular_por_n)
knitr::kable(
head(res_consistencia, 12),
caption = "Primeras filas de la tabla de consistencia (se muestran 12 filas como vista previa).",
digits = 5,
format = "html"
) |>
kableExtra::kable_styling(
bootstrap_options = c("striped", "hover", "bordered"),
full_width = FALSE,
font_size = 12
)
ggplot(res_consistencia, aes(x = n, y = CV, color = Estimador)) +
geom_line(linewidth = 1) +
geom_point(size = 2) +
scale_x_log10() +
labs(
title = "Consistencia: coeficiente de variación vs tamaño muestral",
x = "Tamaño de muestra (escala log10)",
y = "Coeficiente de variación"
) +
theme_minimal()
ggplot(res_consistencia, aes(x = n, y = Media, color = Estimador)) +
geom_line(linewidth = 1) +
geom_point(size = 2) +
geom_hline(yintercept = mu_verdadera, linetype = "dashed", linewidth = 1) +
scale_x_log10() +
labs(
title = "Consistencia: promedio empírico de los estimadores",
subtitle = paste0("Línea punteada: mu verdadera = ", mu_verdadera),
x = "Tamaño de muestra (escala log10)",
y = "Promedio del estimador"
) +
theme_minimal()
ggplot(res_consistencia, aes(x = n, y = MSE, color = Estimador)) +
geom_line(linewidth = 1) +
geom_point(size = 2) +
scale_x_log10() +
labs(
title = "Consistencia: MSE según el tamaño de muestra",
x = "Tamaño de muestra (escala log10)",
y = "MSE"
) +
theme_minimal()
tabla_eficiencia <- res_consistencia |>
filter(n == n_base) |>
select(Estimador, Media, Varianza, CV, MSE) |>
arrange(Varianza)
knitr::kable(
tabla_eficiencia,
caption = "Comparación de eficiencia para n = 10.",
digits = 5,
format = "html"
) |>
kableExtra::kable_styling(
bootstrap_options = c("striped", "hover", "bordered"),
full_width = FALSE,
font_size = 12
)
ggplot(tabla_eficiencia, aes(x = reorder(Estimador, Varianza), y = Varianza, fill = Estimador)) +
geom_col(alpha = 0.85) +
coord_flip() +
labs(
title = "Comparación de varianzas para n = 10",
x = "Estimador",
y = "Varianza"
) +
theme_minimal() +
theme(legend.position = "none")
# Muestra de eficiencia energética (kWh/L)
muestra <- c(6.12, 5.87, 5.45, 6.33, 5.71, 6.04, 5.92, 5.65, 6.18, 5.78, 5.95, 6.21, 5.63, 5.79, 6.11, 5.88, 6.02, 5.76, 5.85, 6.10)
paquetes <- c("knitr", "tidyverse", "broom", "infer", "boot", "kableExtra", "stringr", "summarytools", "dplyr","ggplot2","nortest","moments", "tibble" )
for (paquete in paquetes){
if (!require(paquete, character.only = TRUE)) {
install.packages(paquete)
library(paquete, character.only = TRUE)
} else {
library(paquete, character.only = TRUE)
}
}
library(knitr)
library(tidyverse)
library(broom)
library(infer)
library(boot)
library(kableExtra)
library(stringr)
library(summarytools)
library(dplyr)
library(ggplot2)
library(nortest)
library(moments)
library(tibble)
seed <- 456
set.seed(seed) # Reproducibilidad
n <- length(muestra)
alpha <- 0.05
conf_level <- 1 - alpha
tabla_constantes <- tibble(
Parametro = c(
"Semilla aleatoria",
"Tamaño de muestra",
"Nivel de significancia (alpha)",
"Nivel de confiabilidad"
),
Valor = c(
seed,
n,
alpha,
conf_level
)
)
knitr::kable(
tabla_constantes,
digits = 4,
caption = "Valores a tener en cuenta para este problema.",
format = "html"
) %>%
kable_styling(
bootstrap_options = c("bordered", "striped", "hover"),
full_width = FALSE,
font_size = 11
)
data_temp <- data.frame(muestra = muestra)
lista_resultados <- list()
vars_graph <- c("muestra")
for(v in vars_graph) {
vec <- as.numeric(data_temp[[v]])
n_total <- length(vec)
n_na <- sum(is.na(vec))
pct_na <- (n_na / n_total) * 100
vec_clean <- na.omit(vec)
n_subdataset <- length(vec_clean)
# --- Outliers (1.5 IQR) ---
q1 <- quantile(vec_clean, 0.25)
q3 <- quantile(vec_clean, 0.75)
iqr_val <- q3 - q1
lim_inf <- q1 - 1.5 * iqr_val
lim_sup <- q3 + 1.5 * iqr_val
outliers <- vec_clean[vec_clean < lim_inf | vec_clean > lim_sup]
n_outliers <- length(outliers)
pct_outliers <- (n_outliers / n_subdataset) * 100
tabla <- descr(
vec_clean,
stats = c("n.valid","min","q1","med","q3","max","mean","sd","cv"),
transpose = TRUE
) %>%
tb() %>%
rename(Estadistico = 1) %>%
mutate(
Variable = v,
Outliers_N = n_outliers,
Pct_Outliers = pct_outliers,
Datos_NA = n_na,
Pct_Datos_NA = pct_na
)
lista_resultados[[v]] <- tabla
}
tabla_maestra <- bind_rows(lista_resultados)
knitr::kable(
tabla_maestra,
digits = 2,
caption = "Análisis descriptivo y outliers (Regla 1.5·IQR) de la muestra",
format = "html"
) %>%
kable_styling(
bootstrap_options = c("bordered", "striped", "hover"),
full_width = FALSE,
font_size = 11
)
df <- tibble(x = muestra)
ggplot(df, aes(x = x)) +
geom_histogram(aes(y = after_stat(density)), bins = 10, color = "white") +
geom_density(linewidth = 1) +
labs(
title = "Histograma y densidad de la eficiencia (kWh/L) muestra.",
x = "Eficiencia (kWh/L)",
y = "Densidad"
) +
theme_minimal()
shapiro <- shapiro.test(muestra)
cat("Test de normalidad Shapiro-Wilk\n")
if(shapiro$p.value > alpha){
cat(paste0(
"Conclusión: No se rechaza H0 (p-value = ",
round(shapiro$p.value,4), " y alpha de ",alpha,
").\n"
))
cat("Los datos son compatibles con una distribución normal.")
} else {
cat(paste0(
"Conclusión: Se rechaza H0 (p-value = ",
round(shapiro$p.value,4), " y alpha de ",alpha,
").\n"
))
cat("Los datos no siguen una distribución normal.")
}
qqnorm(muestra,
main = "Q-Q Plot para evaluar normalidad")
qqline(muestra,
col = "red",
lwd = 2)
cat("Resultado de intervalo de confiaza para distribución t")
ic_parametrico <- t.test(muestra, conf.level = conf_level)
ic_parametrico
#función para sacar la media
B = 10000
boot_function <- function(data, indices) {
mean(data[indices])
}
boot_results <- boot(data = muestra, statistic = boot_function, R = B)
# Distribución bootstrap de la media
bootstrap_media <- as.vector(boot_results$t)
# Media y desviación estándar bootstrap
mean_bootstrap <- mean(bootstrap_media)
sd_bootstrap <- sd(bootstrap_media)
# Intervalos de confianza
IC.p   <- boot.ci(boot_results, type = "perc")$percent[4:5]
IC.N   <- boot.ci(boot_results, type = "norm")$normal[2:3]
IC.BCa <- boot.ci(boot_results, type = "bca")$bca[4:5]
# Dataframe para la gráfica
df <- data.frame(bootstrap_media = bootstrap_media)
# Curva normal ajustada
x_vals <- seq(min(bootstrap_media), max(bootstrap_media), length.out = 200)
normal_curve <- data.frame(
x = x_vals,
y = dnorm(x_vals, mean = mean_bootstrap, sd = sd_bootstrap)
)
# Gráfica
plot.boot.c <- ggplot(df, aes(x = bootstrap_media)) +
geom_histogram(aes(y = after_stat(density)),
bins = 30,
fill = "lightblue",
color = "black",
alpha = 0.6) +
geom_line(data = normal_curve,
aes(x = x, y = y),
color = "darkorange",
linewidth = 1.2) +
geom_vline(xintercept = IC.p,
color = "red",
linetype = "dashed",
linewidth = 1.1) +
geom_vline(xintercept = IC.N,
color = "blue",
linetype = "dotted",
linewidth = 1.1) +
geom_vline(xintercept = IC.BCa,
color = "black",
linetype = "dotdash",
linewidth = 1.1) +
labs(
title = "Distribución Bootstrap de la Media",
x = "Media bootstrap (kWh/L)",
y = "Densidad"
) +
theme_minimal() +
theme(plot.title = element_text(hjust = 0.5, size = 14)) +
annotate("text", x = mean(IC.p), y = 6,
label = "IC Percentil", color = "red", angle = 90, vjust = -0.5, size = 3.5) +
annotate("text", x = mean(IC.N), y = 5,
label = "IC Normal", color = "blue", angle = 90, vjust = -0.5, size = 3.5) +
annotate("text", x = mean(IC.BCa), y = 4,
label = "IC BCa", color = "black", angle = 90, vjust = -0.5, size = 3.5)
print(plot.boot.c)
comparacion <- tibble(
Metodo = c("Paramétrico t",
"Bootstrap Percentil",
"Bootstrap Normal",
"Bootstrap BCa"),
IC_INFERIOR = c(ic_parametrico$conf.int[1],
IC.p[1],
IC.N[1],
IC.BCa[1]),
IC_SUPERIOR = c(ic_parametrico$conf.int[2],
IC.p[2],
IC.N[2],
IC.BCa[2])
)
knitr::kable(
comparacion,
digits = 4,
caption = "Comparativo de intervalos de confianza",
format = "html"
) %>%
kable_styling(
bootstrap_options = c("bordered", "striped", "hover"),
full_width = FALSE,
font_size = 11
)
# options(repos = c(CRAN = "https://cloud.r-project.org"))
# Función para calcular la estadística de interés (en este caso, la media)
boot_function <- function(data, indices) {
return(var(data[indices]))
}
# Generar muestras bootstrap usando la librería boot
boot_results <- boot(data = muestra, statistic = boot_function, R = B)
# Obtener la distribución de medias bootstrap
bootstrap_var <- boot_results$t
# Test de Anderson-Darling
ad_test <- ad.test(bootstrap_var)
# Test de Cramer-von Mises
cvm_test <- cvm.test(bootstrap_var)
# Test de Lilliefors (Kolmogorov-Smirnov modificado)
lillie_test <- lillie.test(bootstrap_var)
# Test de D'Agostino-Pearson (manual: usa asimetría y curtosis)
skewness_value <- skewness(bootstrap_var)
kurtosis_value <- kurtosis(bootstrap_var)
# Mostrar resultados
#list(
#  Anderson_Darling_p_value = ad_test$p.value,
#  Cramer_von_Mises_p_value = cvm_test$p.value,
#  Lilliefors_p_value = lillie_test$p.value,
#  DAgostino_Pearson_Skewness = skewness_value,
#  DAgostino_Pearson_Kurtosis = kurtosis_value
#)
tabla_tests <- tibble(
Test = c(
"Anderson-Darling p-valor",
"Cramer-von Mises p-valor",
"Lilliefors p-valor",
"D’Agostino-Pearson Skewness",
"D’Agostino-Pearson Kurtosis"
),
Resultado = c(
ad_test$p.value,
cvm_test$p.value,
lillie_test$p.value,
skewness_value,
kurtosis_value
),
Interpretacion = c(
ifelse(ad_test$p.value < 0.01,
"Se rechaza la normalidad, pues valor-p < 0.01.",
"No se rechaza la normalidad."),
ifelse(cvm_test$p.value < 0.01,
"Se rechaza la normalidad, pues valor-p < 0.01.",
"No se rechaza la normalidad."),
ifelse(lillie_test$p.value < 0.01,
"Se rechaza la normalidad, pues valor-p < 0.01.",
"No se rechaza la normalidad."),
ifelse(abs(skewness_value) < 0.5,
"Indica que la distribución es casi simétrica.",
"Indica presencia de asimetría."),
ifelse(abs(kurtosis_value - 3) < 0.5,
"Es cercano a 3, lo que sugiere colas similares a la normal.",
"Las colas difieren de una distribución normal.")
)
)
knitr::kable(
tabla_tests,
digits = 6,
caption = "Resultados de tests de normalidad y medidas de simetría",
format = "html"
) %>%
kable_styling(
bootstrap_options = c("bordered", "striped", "hover"),
full_width = FALSE,
font_size = 11
)
